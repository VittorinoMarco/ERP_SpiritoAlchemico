# PocketBase API URL (usato in dev e build)
PUBLIC_POCKETBASE_URL=https://spiritoalchemico.marcovittorino.com

# Webhook server (node server/webhook.js)
WEBHOOK_PORT=3001
POCKETBASE_URL=http://127.0.0.1:8090
ECCOMMERCE_WEBHOOK_SECRET=your-secret-here
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your-admin-password

# Backup API server (node server/backup.js)
BACKUP_PORT=3002
BACKUP_API_SECRET=optional-secret-for-backup-api
